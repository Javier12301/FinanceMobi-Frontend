# ─── API ──────────────────────────────────────────────────────────────────────
# URL base de la API. En dev local apunta al backend en :3000.
# En producción: https://<dominio>/api
VITE_API_BASE_URL=http://localhost:3000/api

# ─── Google Sign-In ───────────────────────────────────────────────────────────
# Client ID web de Google Cloud Console (APIs & Services → Credentials).
# Se usa para obtener el idToken que se envía a POST /api/auth/google.
VITE_GOOGLE_CLIENT_ID=171866358561-2fg6e7mqfbv5ve7k4kd4f3u504668e81.apps.googleusercontent.com
